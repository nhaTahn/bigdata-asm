PROJECT_NAME=bigdata-asm

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_GPS=bus-gps-raw
KAFKA_TOPIC_DLQ=bus-gps-dlq
KAFKA_STARTING_OFFSETS=earliest

MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=lakehouse

DATA_RAW_PATH=./data/raw
VEHICLE_ROUTE_MAPPING_PATH=./data/vehicle_route_mapping.csv
BRONZE_PATH=./data/lakehouse/bronze/bus_gps
SILVER_PATH=./data/lakehouse/silver/bus_gps
GOLD_PATH=./data/lakehouse/gold
CHECKPOINT_ROOT=./data/checkpoints

REPLAY_MODE=sample
REPLAY_SAMPLE_SIZE=10000
REPLAY_SPEED_MULTIPLIER=10.0
REPLAY_FLUSH_EVERY_N=200

TRIP_GAP_MINUTES=15
MAX_SPEED_KMH=120
MAX_JUMP_METERS=2000

FUEL_LITER_PER_KM=0.28
IDLE_LITER_PER_MINUTE=0.03
CO2_KG_PER_LITER_FUEL=2.68

SPARK_LOCAL_CORES=2
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SHUFFLE_PARTITIONS=2
SPARK_DEFAULT_PARALLELISM=2
